# Copy to .env and adjust for your environment:
#   cp .env.example .env
#
# Docker Compose reads this file automatically for variable substitution.
# run-local.sh also sources .env when present.

# Odoo JSON-RPC endpoint (browser-reachable URL when using Flutter Web)
ODOO_URL=http://localhost:8069

# Odoo database name
ODOO_DB=dev1

# Host port for the Flutter Web container (docker compose up)
WEB_PORT=8080

# Chrome user-data-dir for ./run-local.sh (dev CORS workaround only)
CHROME_USER_DATA_DIR=/tmp/chrome_cors_dev
